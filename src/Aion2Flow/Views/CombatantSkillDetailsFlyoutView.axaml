												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding IncomingDamage.ParryCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding IncomingDamage.ParryRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="12" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Block]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding IncomingDamage.BlockCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding IncomingDamage.BlockRate}" />
											</StackPanel>
