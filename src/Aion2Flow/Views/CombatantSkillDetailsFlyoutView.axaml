															<controls:NumericBlock Grid.Column="3" Value="{Binding SharePercent}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" FractionDigits="1" TrimTrailingZeros="False" UsePercentageNotation="True" />
