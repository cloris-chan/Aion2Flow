												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding IncomingDamage.Criticals}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding IncomingDamage.CriticalRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="7" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Perfect]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding IncomingDamage.PerfectCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
