														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Endurance}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding EnduranceRate}" />
													</StackPanel>
													<StackPanel Grid.Column="14" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Regeneration}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding RegenerationRate}" />
													</StackPanel>
													<StackPanel Grid.Column="15" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Evades}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding EvadeRate}" />
													</StackPanel>
													<StackPanel Grid.Column="16" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Invincible}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding InvincibleRate}" />
													</StackPanel>
													<controls:NumericBlock Grid.Column="17" Value="{Binding SharePercent}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" FractionDigits="1" TrimTrailingZeros="False" UsePercentageNotation="True" />
												</Grid>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
									<TextBlock Text="{Binding Localization[Panel.EmptySkills]}" Foreground="Gray" IsVisible="{Binding IncomingDamage.HasSkills, Converter={StaticResource InverseBooleanConverter}}" />
								</StackPanel>
							</Border>

							<TextBlock Classes="SupportSectionLabel" Margin="2,0,0,0" Text="{Binding Localization[Panel.Support]}" />

							<TabControl>
								<TabItem Header="{Binding Localization[Panel.Healing]}">
									<Border Margin="0,6,0,0" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
										<StackPanel Orientation="Vertical" Spacing="6">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
											<controls:NumericBlock Value="{Binding IncomingHealing.SkillCount}"
																	   VerticalAlignment="Center" />
										</StackPanel>
											<Grid ColumnDefinitions="2*,96,86,96,96,80,56" ColumnSpacing="4">
												<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
												<StackPanel Grid.Column="1" Classes="DetailColumnHeader">
													<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Total]}" />
