<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:conv="clr-namespace:Cloris.Aion2Flow.Converters"
			 xmlns:vm="clr-namespace:Cloris.Aion2Flow.ViewModels"
			 x:Class="Cloris.Aion2Flow.Views.CombatantSkillDetailsFlyoutView"
			 x:DataType="vm:CombatantSkillDetailsFlyoutViewModel">
	<UserControl.Resources>
		<conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
	</UserControl.Resources>

	<UserControl.Styles>
		<Style Selector="Border.ScopeFilterCard">
			<Setter Property="Background" Value="#24171D22" />
			<Setter Property="BorderBrush" Value="#4A6B7782" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="Padding" Value="8,6" />
		</Style>

		<Style Selector="TextBlock.ScopeFilterLabel">
			<Setter Property="Foreground" Value="#B9C4CF" />
			<Setter Property="FontSize" Value="11" />
			<Setter Property="FontWeight" Value="SemiBold" />
		</Style>

		<Style Selector="ComboBox.ScopeFilterComboBox">
			<Setter Property="MinWidth" Value="156" />
			<Setter Property="Height" Value="28" />
		</Style>

		<Style Selector="TextBlock.SupportSectionLabel">
			<Setter Property="Foreground" Value="#C7D2DC" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontWeight" Value="Bold" />
		</Style>
	</UserControl.Styles>

	<Border Background="#90000000" CornerRadius="12" MaxHeight="720" Padding="12">
		<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
			<StackPanel Orientation="Vertical" Spacing="12">
				<StackPanel Orientation="Vertical" Spacing="2">
					<TextBlock Text="{Binding CombatantName}" FontSize="18" FontWeight="Bold" />
				</StackPanel>

				<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
					<Border Grid.Column="0" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="12">
						<StackPanel Orientation="Vertical" Spacing="8">
							<TextBlock Text="{Binding Localization[Panel.Outgoing]}" FontSize="16" FontWeight="Bold" />
							<Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
								<StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Damage]}" Foreground="Gray" />
									<TextBlock Text="{Binding OutgoingDamage.Total, StringFormat={}{0:0}}" FontSize="18" FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Healing]}" Foreground="Gray" />
									<TextBlock Text="{Binding OutgoingHealing.Total, StringFormat={}{0:0}}" FontSize="18" FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="2" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Shield]}" Foreground="Gray" />
									<TextBlock Text="{Binding OutgoingShield.Total, StringFormat={}{0:0}}" FontSize="18" FontWeight="SemiBold" />
								</StackPanel>
							</Grid>
							<Grid ColumnDefinitions="*,*" ColumnSpacing="16">
								<StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Summary.Dps]}" Foreground="Gray" />
									<TextBlock Text="{Binding OutgoingDamage.PerSecond, StringFormat={}{0:0.0}}" FontSize="16" FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Summary.Hps]}" Foreground="Gray" />
									<TextBlock Text="{Binding OutgoingHealing.PerSecond, StringFormat={}{0:0.0}}" FontSize="16" FontWeight="SemiBold" />
								</StackPanel>
							</Grid>
							<Grid ColumnDefinitions="*,*" ColumnSpacing="8">
								<Border Grid.Column="0" Classes="ScopeFilterCard" IsVisible="{Binding OutgoingDamage.HasMultipleScopes}">
									<StackPanel Orientation="Vertical" Spacing="3">
										<TextBlock Classes="ScopeFilterLabel" Text="{Binding Localization[Panel.Damage]}" />
										<ComboBox Classes="ScopeFilterComboBox"
												  ItemsSource="{Binding OutgoingDamage.ScopeOptions}"
												  SelectedItem="{Binding OutgoingDamage.SelectedScope, Mode=TwoWay}"
												  IsEnabled="{Binding OutgoingDamage.HasMultipleScopes}">
											<ComboBox.ItemTemplate>
												<DataTemplate x:DataType="vm:SkillDetailScopeOption">
													<TextBlock Text="{Binding DisplayName}" />
												</DataTemplate>
											</ComboBox.ItemTemplate>
										</ComboBox>
									</StackPanel>
								</Border>
								<Border Grid.Column="1" Classes="ScopeFilterCard" IsVisible="{Binding OutgoingHealing.HasMultipleScopes}">
									<StackPanel Orientation="Vertical" Spacing="3">
										<TextBlock Classes="ScopeFilterLabel" Text="{Binding Localization[Panel.SupportType]}" />
										<ComboBox Classes="ScopeFilterComboBox"
												  ItemsSource="{Binding OutgoingHealing.ScopeOptions}"
												  SelectedItem="{Binding OutgoingHealing.SelectedScope, Mode=TwoWay}"
												  IsEnabled="{Binding OutgoingHealing.HasMultipleScopes}">
											<ComboBox.ItemTemplate>
												<DataTemplate x:DataType="vm:SkillDetailScopeOption">
													<TextBlock Text="{Binding DisplayName}" />
												</DataTemplate>
											</ComboBox.ItemTemplate>
										</ComboBox>
									</StackPanel>
								</Border>
							</Grid>
						</StackPanel>
					</Border>

					<Border Grid.Column="1" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="12">
						<StackPanel Orientation="Vertical" Spacing="8">
							<TextBlock Text="{Binding Localization[Panel.Incoming]}" FontSize="16" FontWeight="Bold" />
							<Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
								<StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Damage]}" Foreground="Gray" />
									<TextBlock Text="{Binding IncomingDamage.Total, StringFormat={}{0:0}}" FontSize="18" FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Healing]}" Foreground="Gray" />
									<TextBlock Text="{Binding IncomingHealing.Total, StringFormat={}{0:0}}" FontSize="18" FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="2" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Shield]}" Foreground="Gray" />
									<TextBlock Text="{Binding IncomingShield.Total, StringFormat={}{0:0}}" FontSize="18" FontWeight="SemiBold" />
								</StackPanel>
							</Grid>
							<Grid ColumnDefinitions="*,*" ColumnSpacing="16">
								<StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Summary.Dps]}" Foreground="Gray" />
									<TextBlock Text="{Binding IncomingDamage.PerSecond, StringFormat={}{0:0.0}}" FontSize="16" FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Summary.Hps]}" Foreground="Gray" />
									<TextBlock Text="{Binding IncomingHealing.PerSecond, StringFormat={}{0:0.0}}" FontSize="16" FontWeight="SemiBold" />
								</StackPanel>
							</Grid>
							<Grid ColumnDefinitions="*,*" ColumnSpacing="8">
								<Border Grid.Column="0" Classes="ScopeFilterCard" IsVisible="{Binding IncomingDamage.HasMultipleScopes}">
									<StackPanel Orientation="Vertical" Spacing="3">
										<TextBlock Classes="ScopeFilterLabel" Text="{Binding Localization[Panel.Damage]}" />
										<ComboBox Classes="ScopeFilterComboBox"
												  ItemsSource="{Binding IncomingDamage.ScopeOptions}"
												  SelectedItem="{Binding IncomingDamage.SelectedScope, Mode=TwoWay}"
												  IsEnabled="{Binding IncomingDamage.HasMultipleScopes}">
											<ComboBox.ItemTemplate>
												<DataTemplate x:DataType="vm:SkillDetailScopeOption">
													<TextBlock Text="{Binding DisplayName}" />
												</DataTemplate>
											</ComboBox.ItemTemplate>
										</ComboBox>
									</StackPanel>
								</Border>
								<Border Grid.Column="1" Classes="ScopeFilterCard" IsVisible="{Binding IncomingHealing.HasMultipleScopes}">
									<StackPanel Orientation="Vertical" Spacing="3">
										<TextBlock Classes="ScopeFilterLabel" Text="{Binding Localization[Panel.SupportType]}" />
										<ComboBox Classes="ScopeFilterComboBox"
												  ItemsSource="{Binding IncomingHealing.ScopeOptions}"
												  SelectedItem="{Binding IncomingHealing.SelectedScope, Mode=TwoWay}"
												  IsEnabled="{Binding IncomingHealing.HasMultipleScopes}">
											<ComboBox.ItemTemplate>
												<DataTemplate x:DataType="vm:SkillDetailScopeOption">
													<TextBlock Text="{Binding DisplayName}" />
												</DataTemplate>
											</ComboBox.ItemTemplate>
										</ComboBox>
									</StackPanel>
								</Border>
							</Grid>
						</StackPanel>
					</Border>
				</Grid>

				<TabControl>
					<TabItem Header="{Binding Localization[Panel.Outgoing]}">
						<StackPanel Margin="0,6,0,0" Orientation="Vertical" Spacing="10">
							<Border Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
								<StackPanel Orientation="Vertical" Spacing="6">
									<StackPanel Orientation="Vertical" Spacing="4">
										<TextBlock Text="{Binding Localization[Panel.Damage]}" FontSize="14" FontWeight="Bold" />
										<StackPanel Orientation="Horizontal" Spacing="8">
											<StackPanel Orientation="Horizontal" Spacing="4">
												<TextBlock Text="{Binding Localization[Summary.Attacks]}" FontWeight="Bold" />
												<TextBlock Text="{Binding OutgoingDamage.Attempts}" />
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="4">
												<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
												<TextBlock Text="{Binding OutgoingDamage.SkillCount}" />
											</StackPanel>
										</StackPanel>
									</StackPanel>
									<Grid ColumnDefinitions="2*,72,64,64,108,80,96,96,96,96,96,96,96,96,96,96,96,48" ColumnSpacing="4">
										<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
										<TextBlock Grid.Column="1" Text="{Binding Localization[Column.Total]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
										<TextBlock Grid.Column="2" Text="{Binding Localization[Column.Direct]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
										<TextBlock Grid.Column="3" Text="{Binding Localization[Column.PeriodicDamage]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
										<TextBlock Grid.Column="4" Text="{Binding OutgoingDamage.HitCountColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="5" Text="{Binding OutgoingDamage.PeriodicHitsColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="6" Text="{Binding OutgoingDamage.CriticalColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="7" Text="{Binding OutgoingDamage.PerfectColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="8" Text="{Binding OutgoingDamage.SmiteColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="9" Text="{Binding OutgoingDamage.MultiHitColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="10" Text="{Binding OutgoingDamage.BackColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="11" Text="{Binding OutgoingDamage.ParryColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="12" Text="{Binding OutgoingDamage.BlockColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="13" Text="{Binding OutgoingDamage.EnduranceColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="14" Text="{Binding OutgoingDamage.RegenerationColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="15" Text="{Binding OutgoingDamage.EvadeColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="16" Text="{Binding OutgoingDamage.InvincibleColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="17" Text="{Binding Localization[Column.Share]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
									</Grid>
									<ItemsControl ItemsSource="{Binding OutgoingDamage.Rows}">
										<ItemsControl.ItemTemplate>
											<DataTemplate x:DataType="vm:SkillDetailRowViewModel">
												<Grid ColumnDefinitions="2*,72,64,64,108,80,96,96,96,96,96,96,96,96,96,96,96,48" ColumnSpacing="4">
													<TextBlock Grid.Column="0" Text="{Binding SkillName}" Margin="0,2" />
													<TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="2" Text="{Binding DirectAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="3" Text="{Binding PeriodicAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="4" Text="{Binding Hits}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="5" Text="{Binding PeriodicHits}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="6" Text="{Binding CriticalSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="7" Text="{Binding PerfectSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="8" Text="{Binding SmiteSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="9" Text="{Binding MultiHitSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="10" Text="{Binding BackSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="11" Text="{Binding ParrySummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="12" Text="{Binding BlockSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="13" Text="{Binding EnduranceSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="14" Text="{Binding RegenerationSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="15" Text="{Binding EvadeSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="16" Text="{Binding InvincibleSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="17" Text="{Binding SharePercent, StringFormat={}{0:P1}}" Margin="0,2" HorizontalAlignment="Right" />
												</Grid>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
									<TextBlock Text="{Binding Localization[Panel.EmptySkills]}" Foreground="Gray" IsVisible="{Binding OutgoingDamage.HasSkills, Converter={StaticResource InverseBooleanConverter}}" />
								</StackPanel>
							</Border>

							<TextBlock Classes="SupportSectionLabel" Margin="2,0,0,0" Text="{Binding Localization[Panel.Support]}" />

							<TabControl>
								<TabItem Header="{Binding Localization[Panel.Healing]}">
									<Border Margin="0,6,0,0" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
										<StackPanel Orientation="Vertical" Spacing="6">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
												<TextBlock Text="{Binding OutgoingHealing.SkillCount}" />
											</StackPanel>
											<Grid ColumnDefinitions="2*,96,86,96,96,80,56" ColumnSpacing="4">
												<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
												<TextBlock Grid.Column="1" Text="{Binding OutgoingHealing.TotalColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="2" Text="{Binding OutgoingHealing.HealColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="3" Text="{Binding OutgoingHealing.HotColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="4" Text="{Binding OutgoingHealing.DrainHealColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="5" Text="{Binding OutgoingHealing.HitsColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="6" Text="{Binding Localization[Column.Share]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
											</Grid>
											<ItemsControl ItemsSource="{Binding OutgoingHealing.Rows}">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="vm:SkillDetailRowViewModel">
														<Grid ColumnDefinitions="2*,96,86,96,96,80,56" ColumnSpacing="4">
															<TextBlock Grid.Column="0" Text="{Binding SkillName}" Margin="0,2" />
															<TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="2" Text="{Binding DirectAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="3" Text="{Binding PeriodicAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="4" Text="{Binding DrainAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="5" Text="{Binding Hits}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="6" Text="{Binding SharePercent, StringFormat={}{0:P1}}" Margin="0,2" HorizontalAlignment="Right" />
														</Grid>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<TextBlock Text="{Binding Localization[Panel.EmptySkills]}" Foreground="Gray" IsVisible="{Binding OutgoingHealing.HasSkills, Converter={StaticResource InverseBooleanConverter}}" />
										</StackPanel>
									</Border>
								</TabItem>
								<TabItem Header="{Binding Localization[Panel.Shield]}">
									<Border Margin="0,6,0,0" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
										<StackPanel Orientation="Vertical" Spacing="6">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
												<TextBlock Text="{Binding OutgoingShield.SkillCount}" />
											</StackPanel>
											<Grid ColumnDefinitions="2*,96,80,56" ColumnSpacing="4">
												<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
												<TextBlock Grid.Column="1" Text="{Binding OutgoingShield.TotalColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="2" Text="{Binding OutgoingShield.HitsColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="3" Text="{Binding Localization[Column.Share]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
											</Grid>
											<ItemsControl ItemsSource="{Binding OutgoingShield.Rows}">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="vm:SkillDetailRowViewModel">
														<Grid ColumnDefinitions="2*,96,80,56" ColumnSpacing="4">
															<TextBlock Grid.Column="0" Text="{Binding SkillName}" Margin="0,2" />
															<TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="2" Text="{Binding Hits}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="3" Text="{Binding SharePercent, StringFormat={}{0:P1}}" Margin="0,2" HorizontalAlignment="Right" />
														</Grid>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<TextBlock Text="{Binding Localization[Panel.EmptySkills]}" Foreground="Gray" IsVisible="{Binding OutgoingShield.HasSkills, Converter={StaticResource InverseBooleanConverter}}" />
										</StackPanel>
									</Border>
								</TabItem>
							</TabControl>
						</StackPanel>
					</TabItem>

					<TabItem Header="{Binding Localization[Panel.Incoming]}">
						<StackPanel Margin="0,6,0,0" Orientation="Vertical" Spacing="10">
							<Border Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
								<StackPanel Orientation="Vertical" Spacing="6">
									<StackPanel Orientation="Vertical" Spacing="4">
										<TextBlock Text="{Binding Localization[Panel.Damage]}" FontSize="14" FontWeight="Bold" />
										<StackPanel Orientation="Horizontal" Spacing="8">
											<StackPanel Orientation="Horizontal" Spacing="4">
												<TextBlock Text="{Binding Localization[Summary.Attacks]}" FontWeight="Bold" />
												<TextBlock Text="{Binding IncomingDamage.Attempts}" />
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="4">
												<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
												<TextBlock Text="{Binding IncomingDamage.SkillCount}" />
											</StackPanel>
										</StackPanel>
									</StackPanel>
									<Grid ColumnDefinitions="2*,72,64,64,108,80,96,96,96,96,96,96,96,96,96,96,96,48" ColumnSpacing="4">
										<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
										<TextBlock Grid.Column="1" Text="{Binding Localization[Column.Total]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
										<TextBlock Grid.Column="2" Text="{Binding Localization[Column.Direct]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
										<TextBlock Grid.Column="3" Text="{Binding Localization[Column.PeriodicDamage]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
										<TextBlock Grid.Column="4" Text="{Binding IncomingDamage.HitCountColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="5" Text="{Binding IncomingDamage.PeriodicHitsColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="6" Text="{Binding IncomingDamage.CriticalColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="7" Text="{Binding IncomingDamage.PerfectColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="8" Text="{Binding IncomingDamage.SmiteColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="9" Text="{Binding IncomingDamage.MultiHitColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="10" Text="{Binding IncomingDamage.BackColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="11" Text="{Binding IncomingDamage.ParryColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="12" Text="{Binding IncomingDamage.BlockColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="13" Text="{Binding IncomingDamage.EnduranceColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="14" Text="{Binding IncomingDamage.RegenerationColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="15" Text="{Binding IncomingDamage.EvadeColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="16" Text="{Binding IncomingDamage.InvincibleColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
										<TextBlock Grid.Column="17" Text="{Binding Localization[Column.Share]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
									</Grid>
									<ItemsControl ItemsSource="{Binding IncomingDamage.Rows}">
										<ItemsControl.ItemTemplate>
											<DataTemplate x:DataType="vm:SkillDetailRowViewModel">
												<Grid ColumnDefinitions="2*,72,64,64,108,80,96,96,96,96,96,96,96,96,96,96,96,48" ColumnSpacing="4">
													<TextBlock Grid.Column="0" Text="{Binding SkillName}" Margin="0,2" />
													<TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="2" Text="{Binding DirectAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="3" Text="{Binding PeriodicAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="4" Text="{Binding Hits}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="5" Text="{Binding PeriodicHits}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="6" Text="{Binding CriticalSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="7" Text="{Binding PerfectSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="8" Text="{Binding SmiteSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="9" Text="{Binding MultiHitSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="10" Text="{Binding BackSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="11" Text="{Binding ParrySummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="12" Text="{Binding BlockSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="13" Text="{Binding EnduranceSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="14" Text="{Binding RegenerationSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="15" Text="{Binding EvadeSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="16" Text="{Binding InvincibleSummary}" Margin="0,2" HorizontalAlignment="Right" />
													<TextBlock Grid.Column="17" Text="{Binding SharePercent, StringFormat={}{0:P1}}" Margin="0,2" HorizontalAlignment="Right" />
												</Grid>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
									<TextBlock Text="{Binding Localization[Panel.EmptySkills]}" Foreground="Gray" IsVisible="{Binding IncomingDamage.HasSkills, Converter={StaticResource InverseBooleanConverter}}" />
								</StackPanel>
							</Border>

							<TextBlock Classes="SupportSectionLabel" Margin="2,0,0,0" Text="{Binding Localization[Panel.Support]}" />

							<TabControl>
								<TabItem Header="{Binding Localization[Panel.Healing]}">
									<Border Margin="0,6,0,0" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
										<StackPanel Orientation="Vertical" Spacing="6">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
												<TextBlock Text="{Binding IncomingHealing.SkillCount}" />
											</StackPanel>
											<Grid ColumnDefinitions="2*,96,86,96,96,80,56" ColumnSpacing="4">
												<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
												<TextBlock Grid.Column="1" Text="{Binding IncomingHealing.TotalColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="2" Text="{Binding IncomingHealing.HealColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="3" Text="{Binding IncomingHealing.HotColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="4" Text="{Binding IncomingHealing.DrainHealColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="5" Text="{Binding IncomingHealing.HitsColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="6" Text="{Binding Localization[Column.Share]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
											</Grid>
											<ItemsControl ItemsSource="{Binding IncomingHealing.Rows}">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="vm:SkillDetailRowViewModel">
														<Grid ColumnDefinitions="2*,96,86,96,96,80,56" ColumnSpacing="4">
															<TextBlock Grid.Column="0" Text="{Binding SkillName}" Margin="0,2" />
															<TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="2" Text="{Binding DirectAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="3" Text="{Binding PeriodicAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="4" Text="{Binding DrainAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="5" Text="{Binding Hits}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="6" Text="{Binding SharePercent, StringFormat={}{0:P1}}" Margin="0,2" HorizontalAlignment="Right" />
														</Grid>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<TextBlock Text="{Binding Localization[Panel.EmptySkills]}" Foreground="Gray" IsVisible="{Binding IncomingHealing.HasSkills, Converter={StaticResource InverseBooleanConverter}}" />
										</StackPanel>
									</Border>
								</TabItem>
								<TabItem Header="{Binding Localization[Panel.Shield]}">
									<Border Margin="0,6,0,0" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
										<StackPanel Orientation="Vertical" Spacing="6">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
												<TextBlock Text="{Binding IncomingShield.SkillCount}" />
											</StackPanel>
											<Grid ColumnDefinitions="2*,96,80,56" ColumnSpacing="4">
												<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
												<TextBlock Grid.Column="1" Text="{Binding IncomingShield.TotalColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="2" Text="{Binding IncomingShield.HitsColumnHeader}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" />
												<TextBlock Grid.Column="3" Text="{Binding Localization[Column.Share]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
											</Grid>
											<ItemsControl ItemsSource="{Binding IncomingShield.Rows}">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="vm:SkillDetailRowViewModel">
														<Grid ColumnDefinitions="2*,96,80,56" ColumnSpacing="4">
															<TextBlock Grid.Column="0" Text="{Binding SkillName}" Margin="0,2" />
															<TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:0}}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="2" Text="{Binding Hits}" Margin="0,2" HorizontalAlignment="Right" />
															<TextBlock Grid.Column="3" Text="{Binding SharePercent, StringFormat={}{0:P1}}" Margin="0,2" HorizontalAlignment="Right" />
														</Grid>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<TextBlock Text="{Binding Localization[Panel.EmptySkills]}" Foreground="Gray" IsVisible="{Binding IncomingShield.HasSkills, Converter={StaticResource InverseBooleanConverter}}" />
										</StackPanel>
									</Border>
								</TabItem>
							</TabControl>
						</StackPanel>
					</TabItem>
				</TabControl>
			</StackPanel>
		</ScrollViewer>
	</Border>
</UserControl>