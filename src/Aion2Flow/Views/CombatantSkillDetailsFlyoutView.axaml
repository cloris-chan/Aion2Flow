										<StackPanel Grid.Column="13" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Endurance]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding IncomingDamage.EnduranceCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding IncomingDamage.EnduranceRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="14" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Regeneration]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding IncomingDamage.RegenerationCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding IncomingDamage.RegenerationRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="15" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Evade]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding IncomingDamage.Evades}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding IncomingDamage.EvadeRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="16" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Invincible]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding IncomingDamage.Invincible}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding IncomingDamage.InvincibleRate}" />
