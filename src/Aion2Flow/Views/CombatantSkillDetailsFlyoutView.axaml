<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:conv="clr-namespace:Cloris.Aion2Flow.Converters"
			 xmlns:controls="clr-namespace:Cloris.Aion2Flow.Controls"
			 xmlns:vm="clr-namespace:Cloris.Aion2Flow.ViewModels"
			 x:Class="Cloris.Aion2Flow.Views.CombatantSkillDetailsFlyoutView"
			 x:DataType="vm:CombatantSkillDetailsFlyoutViewModel">
	<UserControl.Resources>
		<conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
	</UserControl.Resources>

	<UserControl.Styles>
		<Style Selector="controls|NumericBlock">
			<Setter Property="UseGrouping" Value="True" />
		</Style>

		<Style Selector="StackPanel.DetailColumnHeader">
			<Setter Property="Orientation" Value="Vertical" />
			<Setter Property="Spacing" Value="2" />
		</Style>

		<Style Selector="TextBlock.DetailColumnHeaderTitle">
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="FontSize" Value="11" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="TextAlignment" Value="Right" />
			<Setter Property="TextWrapping" Value="Wrap" />
		</Style>

		<Style Selector="StackPanel.DetailColumnHeaderValues">
			<Setter Property="Orientation" Value="Horizontal" />
			<Setter Property="Spacing" Value="3" />
			<Setter Property="HorizontalAlignment" Value="Right" />
		</Style>

		<Style Selector="TextBlock.DetailColumnHeaderSlash">
			<Setter Property="FontSize" Value="10" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<Style Selector="controls|NumericBlock.DetailColumnHeaderValue">
			<Setter Property="FontSize" Value="11" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="TextAlignment" Value="Right" />
		</Style>

		<Style Selector="controls|NumericBlock.DetailColumnHeaderRate">
			<Setter Property="FractionDigits" Value="1" />
			<Setter Property="TrimTrailingZeros" Value="False" />
			<Setter Property="UsePercentageNotation" Value="True" />
		</Style>

		<Style Selector="StackPanel.DetailMetricPair">
			<Setter Property="Orientation" Value="Horizontal" />
			<Setter Property="Spacing" Value="3" />
			<Setter Property="HorizontalAlignment" Value="Right" />
		</Style>

		<Style Selector="TextBlock.DetailMetricSlash">
			<Setter Property="FontSize" Value="10" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<Style Selector="controls|NumericBlock.DetailMetricValue">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="TextAlignment" Value="Right" />
		</Style>

		<Style Selector="controls|NumericBlock.DetailMetricRate">
			<Setter Property="FractionDigits" Value="1" />
			<Setter Property="TrimTrailingZeros" Value="False" />
			<Setter Property="UsePercentageNotation" Value="True" />
		</Style>

		<Style Selector="Border.ScopeFilterCard">
			<Setter Property="Background" Value="#24171D22" />
			<Setter Property="BorderBrush" Value="#4A6B7782" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="Padding" Value="8,6" />
		</Style>

		<Style Selector="TextBlock.ScopeFilterLabel">
			<Setter Property="Foreground" Value="#B9C4CF" />
			<Setter Property="FontSize" Value="11" />
			<Setter Property="FontWeight" Value="SemiBold" />
		</Style>

		<Style Selector="ComboBox.ScopeFilterComboBox">
			<Setter Property="MinWidth" Value="156" />
			<Setter Property="Height" Value="28" />
		</Style>

		<Style Selector="TextBlock.SupportSectionLabel">
			<Setter Property="Foreground" Value="#C7D2DC" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="FontWeight" Value="Bold" />
		</Style>
	</UserControl.Styles>

	<Border Background="#90000000" CornerRadius="12" MaxHeight="720" Padding="12">
		<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
			<StackPanel Orientation="Vertical" Spacing="12">
				<StackPanel Orientation="Vertical" Spacing="2">
					<TextBlock Text="{Binding CombatantName}" FontSize="18" FontWeight="Bold" />
				</StackPanel>

				<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
					<Border Grid.Column="0" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="12">
						<StackPanel Orientation="Vertical" Spacing="8">
							<TextBlock Text="{Binding Localization[Panel.Outgoing]}" FontSize="16" FontWeight="Bold" />
							<Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
								<StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Damage]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding OutgoingDamage.Total}"
															   FontSize="18"
															   FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Healing]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding OutgoingHealing.Total}"
															   FontSize="18"
															   FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="2" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Shield]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding OutgoingShield.Total}"
															   FontSize="18"
															   FontWeight="SemiBold" />
								</StackPanel>
							</Grid>
							<Grid ColumnDefinitions="*,*" ColumnSpacing="16">
								<StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Summary.Dps]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding OutgoingDamage.PerSecond}"
															   FontSize="16"
															   FontWeight="SemiBold"
															   FractionDigits="1"
															   TrimTrailingZeros="False" />
								</StackPanel>
								<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Summary.Hps]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding OutgoingHealing.PerSecond}"
															   FontSize="16"
															   FontWeight="SemiBold"
															   FractionDigits="1"
															   TrimTrailingZeros="False" />
								</StackPanel>
							</Grid>
							<Grid ColumnDefinitions="*,*" ColumnSpacing="8">
								<Border Grid.Column="0" Classes="ScopeFilterCard" IsVisible="{Binding OutgoingDamage.HasMultipleScopes}">
									<StackPanel Orientation="Vertical" Spacing="3">
										<TextBlock Classes="ScopeFilterLabel" Text="{Binding Localization[Panel.Damage]}" />
										<ComboBox Classes="ScopeFilterComboBox"
												  ItemsSource="{Binding OutgoingDamage.ScopeOptions}"
												  SelectedItem="{Binding OutgoingDamage.SelectedScope, Mode=TwoWay}"
												  IsEnabled="{Binding OutgoingDamage.HasMultipleScopes}">
											<ComboBox.ItemTemplate>
												<DataTemplate x:DataType="vm:SkillDetailScopeOption">
													<TextBlock Text="{Binding DisplayName}" />
												</DataTemplate>
											</ComboBox.ItemTemplate>
										</ComboBox>
									</StackPanel>
								</Border>
								<Border Grid.Column="1" Classes="ScopeFilterCard" IsVisible="{Binding OutgoingHealing.HasMultipleScopes}">
									<StackPanel Orientation="Vertical" Spacing="3">
										<TextBlock Classes="ScopeFilterLabel" Text="{Binding Localization[Panel.SupportType]}" />
										<ComboBox Classes="ScopeFilterComboBox"
												  ItemsSource="{Binding OutgoingHealing.ScopeOptions}"
												  SelectedItem="{Binding OutgoingHealing.SelectedScope, Mode=TwoWay}"
												  IsEnabled="{Binding OutgoingHealing.HasMultipleScopes}">
											<ComboBox.ItemTemplate>
												<DataTemplate x:DataType="vm:SkillDetailScopeOption">
													<TextBlock Text="{Binding DisplayName}" />
												</DataTemplate>
											</ComboBox.ItemTemplate>
										</ComboBox>
									</StackPanel>
								</Border>
							</Grid>
						</StackPanel>
					</Border>

					<Border Grid.Column="1" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="12">
						<StackPanel Orientation="Vertical" Spacing="8">
							<TextBlock Text="{Binding Localization[Panel.Incoming]}" FontSize="16" FontWeight="Bold" />
							<Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
								<StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Damage]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding IncomingDamage.Total}"
															   FontSize="18"
															   FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Healing]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding IncomingHealing.Total}"
															   FontSize="18"
															   FontWeight="SemiBold" />
								</StackPanel>
								<StackPanel Grid.Column="2" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Panel.Shield]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding IncomingShield.Total}"
															   FontSize="18"
															   FontWeight="SemiBold" />
								</StackPanel>
							</Grid>
							<Grid ColumnDefinitions="*,*" ColumnSpacing="16">
								<StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Summary.Dps]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding IncomingDamage.PerSecond}"
															   FontSize="16"
															   FontWeight="SemiBold"
															   FractionDigits="1"
															   TrimTrailingZeros="False" />
								</StackPanel>
								<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
									<TextBlock Text="{Binding Localization[Summary.Hps]}" Foreground="Gray" />
									<controls:NumericBlock Value="{Binding IncomingHealing.PerSecond}"
															   FontSize="16"
															   FontWeight="SemiBold"
															   FractionDigits="1"
															   TrimTrailingZeros="False" />
								</StackPanel>
							</Grid>
							<Grid ColumnDefinitions="*,*" ColumnSpacing="8">
								<Border Grid.Column="0" Classes="ScopeFilterCard" IsVisible="{Binding IncomingDamage.HasMultipleScopes}">
									<StackPanel Orientation="Vertical" Spacing="3">
										<TextBlock Classes="ScopeFilterLabel" Text="{Binding Localization[Panel.Damage]}" />
										<ComboBox Classes="ScopeFilterComboBox"
												  ItemsSource="{Binding IncomingDamage.ScopeOptions}"
												  SelectedItem="{Binding IncomingDamage.SelectedScope, Mode=TwoWay}"
												  IsEnabled="{Binding IncomingDamage.HasMultipleScopes}">
											<ComboBox.ItemTemplate>
												<DataTemplate x:DataType="vm:SkillDetailScopeOption">
													<TextBlock Text="{Binding DisplayName}" />
												</DataTemplate>
											</ComboBox.ItemTemplate>
										</ComboBox>
									</StackPanel>
								</Border>
								<Border Grid.Column="1" Classes="ScopeFilterCard" IsVisible="{Binding IncomingHealing.HasMultipleScopes}">
									<StackPanel Orientation="Vertical" Spacing="3">
										<TextBlock Classes="ScopeFilterLabel" Text="{Binding Localization[Panel.SupportType]}" />
										<ComboBox Classes="ScopeFilterComboBox"
												  ItemsSource="{Binding IncomingHealing.ScopeOptions}"
												  SelectedItem="{Binding IncomingHealing.SelectedScope, Mode=TwoWay}"
												  IsEnabled="{Binding IncomingHealing.HasMultipleScopes}">
											<ComboBox.ItemTemplate>
												<DataTemplate x:DataType="vm:SkillDetailScopeOption">
													<TextBlock Text="{Binding DisplayName}" />
												</DataTemplate>
											</ComboBox.ItemTemplate>
										</ComboBox>
									</StackPanel>
								</Border>
							</Grid>
						</StackPanel>
					</Border>
				</Grid>

				<TabControl>
					<TabItem Header="{Binding Localization[Panel.Outgoing]}">
						<StackPanel Margin="0,6,0,0" Orientation="Vertical" Spacing="10">
							<Border Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
								<StackPanel Orientation="Vertical" Spacing="6">
									<StackPanel Orientation="Vertical" Spacing="4">
										<TextBlock Text="{Binding Localization[Panel.Damage]}" FontSize="14" FontWeight="Bold" />
										<StackPanel Orientation="Horizontal" Spacing="8">
											<StackPanel Orientation="Horizontal" Spacing="4">
												<TextBlock Text="{Binding Localization[Summary.Attacks]}" FontWeight="Bold" />
												<controls:NumericBlock Value="{Binding OutgoingDamage.Attempts}"
																		   VerticalAlignment="Center" />
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="4">
												<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
												<controls:NumericBlock Value="{Binding OutgoingDamage.SkillCount}"
																		   VerticalAlignment="Center" />
											</StackPanel>
										</StackPanel>
									</StackPanel>
									<Grid ColumnDefinitions="2*,72,64,64,120,80,112,112,112,112,112,112,112,112,112,112,112,48" ColumnSpacing="4">
										<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
										<TextBlock Grid.Column="1" Text="{Binding Localization[Column.Total]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
										<TextBlock Grid.Column="2" Text="{Binding Localization[Column.Direct]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
										<TextBlock Grid.Column="3" Text="{Binding Localization[Column.PeriodicDamage]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
										<StackPanel Grid.Column="4" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.HitCount]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.Hits}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.HitRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="5" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.PeriodicHits]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.PeriodicHits}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="6" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Critical]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.Criticals}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.CriticalRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="7" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Perfect]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.PerfectCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.PerfectRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="8" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Smite]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.SmiteCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.SmiteRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="9" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.MultiHit]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.MultiHitCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.MultiHitRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="10" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Back]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.BackCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.BackRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="11" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Parry]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.ParryCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.ParryRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="12" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Block]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.BlockCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.BlockRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="13" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Endurance]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.EnduranceCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.EnduranceRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="14" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Regeneration]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.RegenerationCount}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.RegenerationRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="15" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Evade]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.Evades}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.EvadeRate}" />
											</StackPanel>
										</StackPanel>
										<StackPanel Grid.Column="16" Classes="DetailColumnHeader">
											<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Invincible]}" />
											<StackPanel Classes="DetailColumnHeaderValues">
												<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingDamage.Invincible}" />
												<TextBlock Classes="DetailColumnHeaderSlash" Text="/" />
												<controls:NumericBlock Classes="DetailColumnHeaderValue DetailColumnHeaderRate" Value="{Binding OutgoingDamage.InvincibleRate}" />
											</StackPanel>
										</StackPanel>
										<TextBlock Grid.Column="17" Text="{Binding Localization[Column.Share]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
									</Grid>
									<ItemsControl ItemsSource="{Binding OutgoingDamage.Rows}">
										<ItemsControl.ItemTemplate>
											<DataTemplate x:DataType="vm:SkillDetailRowViewModel">
												<Grid ColumnDefinitions="2*,72,64,64,120,80,112,112,112,112,112,112,112,112,112,112,112,48" ColumnSpacing="4">
													<TextBlock Grid.Column="0" Text="{Binding SkillName}" Margin="0,2" />
													<controls:NumericBlock Grid.Column="1" Value="{Binding TotalAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<controls:NumericBlock Grid.Column="2" Value="{Binding DirectAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<controls:NumericBlock Grid.Column="3" Value="{Binding PeriodicAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<controls:NumericBlock Grid.Column="4" Value="{Binding Hits}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<controls:NumericBlock Grid.Column="5" Value="{Binding PeriodicHits}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<StackPanel Grid.Column="6" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Criticals}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding CriticalRate}" />
													</StackPanel>
													<StackPanel Grid.Column="7" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Perfect}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding PerfectRate}" />
													</StackPanel>
													<StackPanel Grid.Column="8" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Smite}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding SmiteRate}" />
													</StackPanel>
													<StackPanel Grid.Column="9" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding MultiHit}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding MultiHitRate}" />
													</StackPanel>
													<StackPanel Grid.Column="10" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Back}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding BackRate}" />
													</StackPanel>
													<StackPanel Grid.Column="11" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Parry}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding ParryRate}" />
													</StackPanel>
													<StackPanel Grid.Column="12" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Block}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding BlockRate}" />
													</StackPanel>
													<StackPanel Grid.Column="13" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Endurance}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding EnduranceRate}" />
													</StackPanel>
													<StackPanel Grid.Column="14" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Regeneration}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding RegenerationRate}" />
													</StackPanel>
													<StackPanel Grid.Column="15" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Evades}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding EvadeRate}" />
													</StackPanel>
													<StackPanel Grid.Column="16" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Invincible}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding InvincibleRate}" />
													</StackPanel>
													<controls:NumericBlock Grid.Column="17" Value="{Binding SharePercent}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" FractionDigits="1" TrimTrailingZeros="False" UsePercentageNotation="True" />
												</Grid>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
									<TextBlock Text="{Binding Localization[Panel.EmptySkills]}" Foreground="Gray" IsVisible="{Binding OutgoingDamage.HasSkills, Converter={StaticResource InverseBooleanConverter}}" />
								</StackPanel>
							</Border>

							<TextBlock Classes="SupportSectionLabel" Margin="2,0,0,0" Text="{Binding Localization[Panel.Support]}" />

							<TabControl>
								<TabItem Header="{Binding Localization[Panel.Healing]}">
									<Border Margin="0,6,0,0" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
										<StackPanel Orientation="Vertical" Spacing="6">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
											<controls:NumericBlock Value="{Binding OutgoingHealing.SkillCount}"
																	   VerticalAlignment="Center" />
										</StackPanel>
											<Grid ColumnDefinitions="2*,96,86,96,96,80,56" ColumnSpacing="4">
												<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
												<StackPanel Grid.Column="1" Classes="DetailColumnHeader">
													<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Total]}" />
													<StackPanel Classes="DetailColumnHeaderValues">
														<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingHealing.Total}" />
													</StackPanel>
												</StackPanel>
												<StackPanel Grid.Column="2" Classes="DetailColumnHeader">
													<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Heal]}" />
													<StackPanel Classes="DetailColumnHeaderValues">
														<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingHealing.DirectTotal}" />
													</StackPanel>
												</StackPanel>
												<StackPanel Grid.Column="3" Classes="DetailColumnHeader">
													<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Hot]}" />
													<StackPanel Classes="DetailColumnHeaderValues">
														<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingHealing.PeriodicTotal}" />
													</StackPanel>
												</StackPanel>
												<StackPanel Grid.Column="4" Classes="DetailColumnHeader">
													<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.DrainHeal]}" />
													<StackPanel Classes="DetailColumnHeaderValues">
														<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingHealing.DrainTotal}" />
													</StackPanel>
												</StackPanel>
												<StackPanel Grid.Column="5" Classes="DetailColumnHeader">
													<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.HitCount]}" />
													<StackPanel Classes="DetailColumnHeaderValues">
														<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingHealing.Hits}" />
													</StackPanel>
												</StackPanel>
												<TextBlock Grid.Column="6" Text="{Binding Localization[Column.Share]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
											</Grid>
											<ItemsControl ItemsSource="{Binding OutgoingHealing.Rows}">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="vm:SkillDetailRowViewModel">
														<Grid ColumnDefinitions="2*,96,86,96,96,80,56" ColumnSpacing="4">
															<TextBlock Grid.Column="0" Text="{Binding SkillName}" Margin="0,2" />
															<controls:NumericBlock Grid.Column="1" Value="{Binding TotalAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
															<controls:NumericBlock Grid.Column="2" Value="{Binding DirectAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
															<controls:NumericBlock Grid.Column="3" Value="{Binding PeriodicAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
															<controls:NumericBlock Grid.Column="4" Value="{Binding DrainAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
															<controls:NumericBlock Grid.Column="5" Value="{Binding Hits}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
															<controls:NumericBlock Grid.Column="6" Value="{Binding SharePercent}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" FractionDigits="1" TrimTrailingZeros="False" UsePercentageNotation="True" />
														</Grid>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
											<TextBlock Text="{Binding Localization[Panel.EmptySkills]}" Foreground="Gray" IsVisible="{Binding OutgoingHealing.HasSkills, Converter={StaticResource InverseBooleanConverter}}" />
										</StackPanel>
									</Border>
								</TabItem>
								<TabItem Header="{Binding Localization[Panel.Shield]}">
									<Border Margin="0,6,0,0" Background="#30111111" BorderBrush="#50808080" BorderThickness="1" CornerRadius="8" Padding="8">
										<StackPanel Orientation="Vertical" Spacing="6">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="{Binding Localization[Summary.Skills]}" FontWeight="Bold" />
											<controls:NumericBlock Value="{Binding OutgoingShield.SkillCount}"
																	   VerticalAlignment="Center" />
										</StackPanel>
											<Grid ColumnDefinitions="2*,96,80,56" ColumnSpacing="4">
												<TextBlock Grid.Column="0" Text="{Binding Localization[Column.Skill]}" FontWeight="Bold" />
												<StackPanel Grid.Column="1" Classes="DetailColumnHeader">
													<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.Total]}" />
													<StackPanel Classes="DetailColumnHeaderValues">
														<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingShield.Total}" />
													</StackPanel>
												</StackPanel>
												<StackPanel Grid.Column="2" Classes="DetailColumnHeader">
													<TextBlock Classes="DetailColumnHeaderTitle" Text="{Binding Localization[Column.HitCount]}" />
													<StackPanel Classes="DetailColumnHeaderValues">
														<controls:NumericBlock Classes="DetailColumnHeaderValue" Value="{Binding OutgoingShield.Hits}" />
													</StackPanel>
												</StackPanel>
												<TextBlock Grid.Column="3" Text="{Binding Localization[Column.Share]}" FontWeight="Bold" HorizontalAlignment="Right" TextAlignment="Right" />
