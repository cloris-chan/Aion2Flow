									</Grid>
									<ItemsControl ItemsSource="{Binding IncomingDamage.Rows}">
										<ItemsControl.ItemTemplate>
											<DataTemplate x:DataType="vm:SkillDetailRowViewModel">
												<Grid ColumnDefinitions="2*,72,64,64,120,80,112,112,112,112,112,112,112,112,112,112,112,48" ColumnSpacing="4">
													<TextBlock Grid.Column="0" Text="{Binding SkillName}" Margin="0,2" />
													<controls:NumericBlock Grid.Column="1" Value="{Binding TotalAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<controls:NumericBlock Grid.Column="2" Value="{Binding DirectAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<controls:NumericBlock Grid.Column="3" Value="{Binding PeriodicAmount}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<controls:NumericBlock Grid.Column="4" Value="{Binding Hits}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<controls:NumericBlock Grid.Column="5" Value="{Binding PeriodicHits}" Margin="0,2" HorizontalAlignment="Stretch" TextAlignment="Right" />
													<StackPanel Grid.Column="6" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Criticals}" />
														<TextBlock Classes="DetailMetricSlash" Text="/" />
														<controls:NumericBlock Classes="DetailMetricValue DetailMetricRate" Value="{Binding CriticalRate}" />
													</StackPanel>
													<StackPanel Grid.Column="7" Classes="DetailMetricPair" Margin="0,2">
														<controls:NumericBlock Classes="DetailMetricValue" Value="{Binding Perfect}" />
