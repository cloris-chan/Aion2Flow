<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:markups="clr-namespace:Cloris.Aion2Flow.Markups"
        xmlns:vm="clr-namespace:Cloris.Aion2Flow.ViewModels"
        xmlns:controls="clr-namespace:Cloris.Aion2Flow.Controls"
        xmlns:views="clr-namespace:Cloris.Aion2Flow.Views"
        xmlns:conv="clr-namespace:Cloris.Aion2Flow.Converters"
        x:Class="Cloris.Aion2Flow.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Classes="OverlayWindow"
        WindowDecorations="None"
        TransparencyLevelHint="AcrylicBlur"
        Width="280"
        SizeToContent="Height"
        CanResize="False"
        CanMaximize="False"
        Title="Aion2Flow"
        Icon="/Assets/Images/Aion2Flow.png"
        Topmost="{Binding IsTopMost}">

    <Window.Resources>
        <conv:ClassToIconConverter x:Key="ClassToIconConverter" />
    </Window.Resources>

    <Window.Styles>
        <StyleInclude Source="avares://Aion2Flow/Styles/OverlayTheme.axaml" />
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto"
          RowSpacing="2"
          Margin="3">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="2"
              Margin="1,0,1,2">
            <Button Grid.Column="0"
                    Classes="WindowBtn MainWindowBtn RefreshBtn"
                    Command="{Binding ResetCommand}"
                    IsEnabled="{Binding IsCapturing}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="{markups:Translate Action_Reset}">
                <PathIcon Data="{StaticResource arrows-rotate}" />
            </Button>

            <Border Grid.Column="1"
                    Classes="TitleBarDragRegion"
                    PointerPressed="TitleBarDragRegionPointerPressed">
                <controls:NumericBlock Classes="OverlayHeaderMetric"
                                       Value="{Binding BattleTimeSeconds}"
                                       FractionDigits="1"
                                       TrimTrailingZeros="False"
                                       Suffix="s"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="2"
                        Classes="TitleBarActions"
                        Orientation="Horizontal"
                        Spacing="2">
                <Button Classes="WindowBtn MainWindowBtn MinBtn"
                        Click="Minimize">
                    <PathIcon Data="{StaticResource window-minimize}" />
                </Button>

                <Button Classes="WindowBtn MainWindowBtn CloseBtn"
                        Click="Exit">
                    <PathIcon Data="{StaticResource xmark}" />
                </Button>
            </StackPanel>
        </Grid>

        <controls:AnimatedItemsView Grid.Row="1"
                                     ItemSpacing="1"
                                     ItemsSource="{Binding Combatants}"
                                     SelectedItem="{Binding SelectedCombatant, Mode=TwoWay}"
                                     MaxVisibleItems="{Binding MaxVisibleCombatantRows}">
            <controls:AnimatedItemsView.EmptyTemplate>
                <DataTemplate x:DataType="vm:MainViewModel">
                    <Border Padding="0,10">
                        <TextBlock Classes="OverlayMutedText OverlayEmptyStateText"
                                   Text="{markups:Translate Empty_Combatants}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                </DataTemplate>
            </controls:AnimatedItemsView.EmptyTemplate>

            <controls:AnimatedItemsView.ItemTemplate>
                <DataTemplate x:DataType="vm:CombatantRowViewModel">
                    <Border Name="RowRoot"
                            Classes="OverlayRowCard"
                            Tapped="CombatantRowTapped">
                        <Grid ColumnDefinitions="2,34,*,46,48,36"
                              ColumnSpacing="4">
                            <Border Grid.Column="0"
                                    Name="RowAccent"
                                    Classes="MainRowAccent" />

                            <Panel Grid.Column="1"
                                   Width="34"
                                   Height="34">
                                <Panel Width="30"
                                       Height="30"
                                       ClipToBounds="True"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image Name="BaseImage"
                                           Width="30"
                                           Height="60"
                                           Source="{Binding CharacterClass, Converter={StaticResource ClassToIconConverter}}"
                                           VerticalAlignment="Top" />
                                </Panel>

                                <Image Name="OverlayImage"
                                       Width="32"
                                       Height="32"
                                       Source="/Assets/Images/Overlay.webp"
                                       ZIndex="10"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Panel>

                            <TextBlock Grid.Column="2"
                                       Classes="OverlayRowName"
                                       Text="{Binding DisplayName}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />

                            <controls:NumericBlock Grid.Column="3"
                                                    Classes="OverlayRowMetricStrong"
                                                    Value="{Binding DamagePerSecond}"
                                                    VerticalAlignment="Center"
                                                   HorizontalAlignment="Stretch"
                                                   UseCompactNotation="True"
                                                   CompactThreshold="1000"
                                                   CompactSignificantDigits="3" />

                            <controls:NumericBlock Grid.Column="4"
                                                     Classes="OverlayRowMetric"
                                                     Value="{Binding Damage}"
                                                     VerticalAlignment="Center"
                                                    HorizontalAlignment="Stretch"
                                                    UseCompactNotation="True"
                                                    CompactThreshold="1000"
                                                    CompactSignificantDigits="3" />

                            <controls:NumericBlock Grid.Column="5"
                                                   Classes="OverlayRowMetricShare"
                                                   Value="{Binding DamageContribution}"
                                                   FractionDigits="1"
                                                   UsePercentageNotation="True"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Stretch" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </controls:AnimatedItemsView.ItemTemplate>
        </controls:AnimatedItemsView>

        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="6"
              Margin="1,2,1,0">
            <Button Grid.Column="0"
                    Classes="BottomBarButton MainBottomBarButton"
                    MinWidth="26"
                    VerticalAlignment="Center"
                    ToolTip.Tip="{Binding SelectedLanguage.DisplayName}">
                <PathIcon Data="{Binding SelectedLanguage.IconGeometry}"
                          Width="15"
                          Height="15" />
                <Button.Flyout>
                    <MenuFlyout Placement="TopEdgeAlignedLeft"
                                ShowMode="Transient"
                                FlyoutPresenterClasses="BottomBarMenuFlyout">
                        <MenuItem Classes="FlyoutMenuItem"
                                  Header="繁體中文"
                                  Tag="zh-TW"
                                  Click="LanguageMenuItemClicked">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource language-zh}"
                                          Width="16"
                                          Height="16" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Classes="FlyoutMenuItem"
                                  Header="English"
                                  Tag="en-US"
                                  Click="LanguageMenuItemClicked">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource language-en}"
                                          Width="16"
                                          Height="16" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Classes="FlyoutMenuItem"
                                  Header="한국어"
                                  Tag="ko-KR"
                                  Click="LanguageMenuItemClicked">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource language-ko}"
                                          Width="16"
                                          Height="16" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center"
                        ToolTip.Tip="{Binding Status}">
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Ellipse Classes="BottomBarStatusDot"
                             Fill="{Binding DriverIndicatorColor}"
                             ToolTip.Tip="{Binding DriverIndicatorToolTip}" />
                    <Ellipse Classes="BottomBarStatusDot"
                             Fill="{Binding GamePortIndicatorColor}"
                             ToolTip.Tip="{Binding GamePortIndicatorToolTip}" />
                    <Ellipse Classes="BottomBarStatusDot"
                             Fill="{Binding CaptureLockIndicatorColor}"
                             ToolTip.Tip="{Binding CaptureLockIndicatorToolTip}" />
                </StackPanel>

                <Border Classes="BottomBarDivider" />

                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center"
                            ToolTip.Tip="{Binding LatencyToolTip}">
                    <PathIcon Classes="BottomBarSignalIcon"
                              Data="{StaticResource wifi}"
                              Foreground="{Binding LatencyIndicatorColor}" />
                    <controls:NumericBlock Classes="BottomBarMetric"
                                           Value="{Binding RoundTripTimeMilliseconds}"
                                           Suffix=" ms"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                <Button Classes="BottomBarButton MainBottomBarButton"
                        CornerRadius="999,0,0,999"
                        MinWidth="26"
                        IsEnabled="{Binding IsViewingArchivedBattle}"
                        Command="{Binding ReturnToLiveCommand}"
                        ToolTip.Tip="{markups:Translate Action_Live}">
                    <PathIcon Data="{StaticResource podcast-line}"
                              Width="13"
                              Height="13" />
                </Button>

                <Border Classes="BottomBarDivider"
                        IsHitTestVisible="False" />

                <Button x:Name="BattleHistoryButton"
                        Classes="BottomBarButton MainBottomBarButton"
                        CornerRadius="0,999,999,0"
                        MinWidth="26"
                        IsEnabled="{Binding HasArchivedBattles}"
                        ToolTip.Tip="{markups:Translate Column_History}">
                    <PathIcon Data="{StaticResource angle-down}"
                              Width="11"
                              Height="11" />
                    <Button.Flyout>
                        <MenuFlyout Placement="TopEdgeAlignedRight"
                                    ShowMode="Transient"
                                    FlyoutPresenterClasses="BottomBarMenuFlyout BottomBarHistoryMenuFlyout" />
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>

    <FlyoutBase.AttachedFlyout>
        <Flyout ShowMode="Transient"
                Closed="FlyoutClosed">
            <views:CombatantDetailsFlyoutView x:Name="CombatantDetailsFlyoutView"
                                              DataContext="{Binding CombatantDetails}" />
        </Flyout>
    </FlyoutBase.AttachedFlyout>
</Window>
